&НаКлиенте
Асинх Процедура ПутьКПапкеНачалоВыбора(Элемент, ДанныеВыбора, ВыборДобавлением, СтандартнаяОбработка)
	Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.ВыборКаталога);
	Диалог.Заголовок = "Выберите файл стандартного списка";
	Диалог.МножественныйВыбор = Ложь;
	Диалог.Каталог = Объект.ПутьКПапке;
	
	ВыбранныеФайлы = Ждать Диалог.ВыбратьАсинх();
	
	Если ВыбранныеФайлы <> Неопределено И ВыбранныеФайлы.Количество() > 0 Тогда
		Объект.ПутьКПапке = ВыбранныеФайлы[0];
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура УчетныеДанныеПоУмолчаниюПриИзменении(Элемент)
	УчетныеДанныеПоУмолчаниюПриИзмененииНаСервере();
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаКлиенте
Процедура УстановитьУчетныеДанныеПоУмолчанию(Команда)
	Если Элементы.УчетныеДанные.ТекущаяСтрока = Неопределено Тогда
		Возврат;
	КонецЕсли;
	
	Объект.УчетныеДанныеПоУмолчанию = Элементы.УчетныеДанные.ТекущаяСтрока;
	ЭтотОбъект.Модифицированность = Истина;
	
	ИзменитьОтображениеЭлементовФормы();
КонецПроцедуры

&НаКлиенте
Процедура ОткрытьКонфигурацию(Команда)
	ИнформационныеБазыКлиент.ОбработатьОткрытиеКонфигуратор(Объект.Ссылка);
	
	ОткрытьКонфигурациюНаСервере();
КонецПроцедуры

