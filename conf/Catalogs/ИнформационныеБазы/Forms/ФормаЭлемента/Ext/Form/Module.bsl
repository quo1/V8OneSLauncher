#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, СтандартнаяОбработка)
	Параметры.Свойство("ТипДобавления", ЭтотОбъект.ТипДобавления);
	
	Если ЭтотОбъект.ТипДобавления = ИнформационныеБазыКлиентСервер.ТипДобавленияНоваяИБ() Тогда
		Элементы.Тип.СписокВыбора.Очистить();
		
		Элементы.Тип.СписокВыбора.Добавить(Перечисления.ТипыИнформационныхБаз.Файловая);
	КонецЕсли;
	
	Если НЕ Объект.Ссылка.Пустая() Тогда
		ЭтотОбъект.УчетныеДанные.Параметры.УстановитьЗначениеПараметра("ЭтаИнформационнаяБаза", Объект.Ссылка);
		
		ИнформационныеБазы.УстановитьНадписьСеансаСКонфигуратором(ЭтотОбъект, Объект.Ссылка);
	КонецЕсли;
	
	УстановитьПризнакНаличияОбязательныхФайлов();
	
	ИзменитьОтображениеЭлементовФормы();
КонецПроцедуры

&НаКлиенте
Процедура ПриОткрытии(Отказ)
	ПодключитьОбработчикОжидания("ПерепроверитьИнформационнуюБазу", 5);
КонецПроцедуры

&НаСервере
Процедура ПослеЗаписиНаСервере(ТекущийОбъект, ПараметрыЗаписи)
	ЭтоЗаписьНового = ТекущийОбъект.ДополнительныеСвойства.Свойство("ЭтоЗаписьНового")
		И ТекущийОбъект.ДополнительныеСвойства.ЭтоЗаписьНового;
	
	Если ЭтотОбъект.ТипДобавления = ИнформационныеБазыКлиентСервер.ТипДобавленияНоваяИБ()
		И ЭтоЗаписьНового
		Тогда
		ПараметрыЗаписи.Вставить("ЭтоЗаписьНового", ТекущийОбъект.ДополнительныеСвойства.ЭтоЗаписьНового);
		ПараметрыЗаписи.Вставить("ПутьКПапкеКВерсииПлатформы", ОбщегоНазначения.ЗначениеРеквизитаОбъекта(Объект.ВерсияПлатформы, "ПутьКПапке"));
		
		Элементы.Тип.СписокВыбора.Очистить();
		
		Элементы.Тип.СписокВыбора.Добавить(Перечисления.ТипыИнформационныхБаз.Файловая);
		Элементы.Тип.СписокВыбора.Добавить(Перечисления.ТипыИнформационныхБаз.Серверная);
		Элементы.Тип.СписокВыбора.Добавить(Перечисления.ТипыИнформационныхБаз.ВебСерверная);
	КонецЕсли;
	
	Если ТекущийОбъект.ДополнительныеСвойства.Свойство("ТипСмененСФайловойНаДругой")
		И ТекущийОбъект.ДополнительныеСвойства.ТипСмененСФайловойНаДругой
		Тогда
		ПараметрыЗаписи.Вставить("ТипСмененСФайловойНаДругой", Истина);
		ПараметрыЗаписи.Вставить("ПутьКУдаляемойПапке", ТекущийОбъект.ДополнительныеСвойства.ПутьКУдаляемойПапке);
	КонецЕсли;
	
	Если ЭтоЗаписьНового Тогда
		ЭтотОбъект.УчетныеДанные.Параметры.УстановитьЗначениеПараметра("ЭтаИнформационнаяБаза", Объект.Ссылка);
	КонецЕсли;
	
	ИзменитьОтображениеЭлементовФормы(Истина);
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗаписи(ПараметрыЗаписи)
	Если ЭтотОбъект.ТипДобавления = ИнформационныеБазыКлиентСервер.ТипДобавленияНоваяИБ()
		И ПараметрыЗаписи.Свойство("ЭтоЗаписьНового")
		И ПараметрыЗаписи.ЭтоЗаписьНового
		Тогда
		ОписаниеИБ = Новый Структура;
		ОписаниеИБ.Вставить("ПутьКПапкеКВерсииПлатформы", ПараметрыЗаписи.ПутьКПапкеКВерсииПлатформы);
		ОписаниеИБ.Вставить("ПутьКПапке", Объект.ПутьКПапке);
		
		ПлатформаКлиент.СоздатьНовуюФайловуюБазу(ОписаниеИБ);
	КонецЕсли;
	
	Если ПараметрыЗаписи.Свойство("ТипСмененСФайловойНаДругой")
		И ПараметрыЗаписи.ТипСмененСФайловойНаДругой
		Тогда
		ИнформационныеБазыКлиент.УдалитьПапкуФайловойБазы(ПараметрыЗаписи.ПутьКУдаляемойПапке);
	КонецЕсли;
КонецПроцедуры

&НаКлиенте
Процедура ПередЗакрытием(Отказ, ЗавершениеРаботы, ТекстПредупреждения, СтандартнаяОбработка)
	СтандартнаяОбработка = Ложь;
	
	Закрыть(?(Объект.Ссылка.Пустая(), Неопределено, Объект.Ссылка));
КонецПроцедуры

#КонецОбласти

