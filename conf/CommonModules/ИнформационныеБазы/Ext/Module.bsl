#Область ПрограммныйИнтерфейс

Функция СоздатьГруппу(ОписаниеГруппы) Экспорт
	НоваяГруппа = Справочники.ИнформационныеБазы.СоздатьГруппу();
	НоваяГруппа.Наименование = ОписаниеГруппы.Заголовок;
	НоваяГруппа.Родитель = ОписаниеГруппы.Родитель;
	НоваяГруппа.Идентификатор = ОписаниеГруппы.УникальныйИдентификатор;
	
	НоваяГруппа.ПроверитьЗаполнение();
	
	НоваяГруппа.Записать();
	
	Возврат НоваяГруппа.Ссылка;
КонецФункции

Функция ОписаниеСоздаваемойГруппы() Экспорт
	Описание = Новый Структура;
	Описание.Вставить("Заголовок", ОбщегоНазначенияКлиентСервер.ЗначениеПустойСтроки());
	Описание.Вставить("УникальныйИдентификатор", Новый УникальныйИдентификатор);
	Описание.Вставить("Родитель", Справочники.ИнформационныеБазы.ПустаяСсылка());
	
	Возврат Описание;
КонецФункции

Функция СоздатьФайловуюБазу(ОписаниеФайловойИБ) Экспорт
	НовыйЭлемент = Справочники.ИнформационныеБазы.СоздатьЭлемент();
	НовыйЭлемент.Тип = Перечисления.ТипыИнформационныхБаз.Файловая;
	НовыйЭлемент.Наименование = ОписаниеФайловойИБ.Заголовок;
	НовыйЭлемент.ПутьКПапке = ОписаниеФайловойИБ.ПутьКПапке;
	НовыйЭлемент.Родитель = ОписаниеФайловойИБ.Группа;
	НовыйЭлемент.ПредупреждатьПередОткрытиемПредприятия = ОписаниеФайловойИБ.ПредупреждатьПередОткрытиемПредприятия;
	НовыйЭлемент.ЗапретитьОткрыватьКонфигуратор = ОписаниеФайловойИБ.ЗапретитьОткрыватьКонфигуратор;
	НовыйЭлемент.СкоростьСоединения = ОписаниеФайловойИБ.СкоростьСоединения;
	НовыйЭлемент.ВерсияПлатформы = ОписаниеФайловойИБ.ВерсияПлатформы;
	
	НовыйЭлемент.ПроверитьЗаполнение();
	
	НовыйЭлемент.Записать();
КонецФункции

Функция ОписаниеСоздаваемойФайловойИБ() Экспорт
	Описание = Новый Структура;
	
	ДобавитьОбщиеСвойстваОписанияИБ(Описание);
	
	Описание.Вставить("Заголовок", Неопределено);
	Описание.Вставить("ПутьКПапке", Неопределено);
	
	Возврат Описание;
КонецФункции

