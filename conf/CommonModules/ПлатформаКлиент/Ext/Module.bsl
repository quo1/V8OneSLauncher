#Область СлужебныеПроцедурыИФункции

Функция ПутьКПриложениТонкогоКлиента(ПутьКПапке)
	Возврат СтрШаблон("%1%2%3", ПутьКПапке, ПолучитьРазделительПутиКлиента(), "1cv8s.exe");
КонецФункции

Функция ПутьКПриложению(ПутьКПапке)
	Возврат СтрШаблон("%1%2%3", ПутьКПапке, ПолучитьРазделительПутиКлиента(), "1cv8.exe");
КонецФункции

Функция КлючЗапускаПредприятия()
	Возврат "ENTERPRISE";
КонецФункции

Функция КлючЗапускаКонфигуратора()
	Возврат "DESIGNER";
КонецФункции

Функция КлючФайловойСтрокиПодключения()
	Возврат "/F";
КонецФункции

Функция КлючСервернойСтрокиПодключения()
	Возврат "/S";
КонецФункции

Функция КлючВебСервернойСтрокиПодключения()
	Возврат "/WS";
КонецФункции

Функция КлючОчисткиКэша()
	Возврат "/ClearCache";
КонецФункции

Функция КлючИмениПользователя()
	Возврат "/N"
КонецФункции

Функция КлючПароляПользователя()
	Возврат "/P"
КонецФункции

#Область Создание

Функция КлючСозданияИБ()
	Возврат "CREATEINFOBASE";
КонецФункции

Функция КлючФайловойСоздаваемойБазы()
	Возврат "File";
КонецФункции

#КонецОбласти

Процедура УказатьУСтрокиПодключенияУчетныеДанные(СтрокаЗапуска, ОписаниеИБ)
	Если ЗначениеЗаполнено(ОписаниеИБ.Логин) Тогда
		СтрокаЗапуска = СтрШаблон("%1 %2 ""%3""", СтрокаЗапуска, КлючИмениПользователя(), ОписаниеИБ.Логин);
	КонецЕсли;
	
	Если ЗначениеЗаполнено(ОписаниеИБ.Пароль) Тогда
		СтрокаЗапуска = СтрШаблон("%1 %2 ""%3""", СтрокаЗапуска, КлючПароляПользователя(), ОписаниеИБ.Пароль);
	КонецЕсли;
КонецПроцедуры

