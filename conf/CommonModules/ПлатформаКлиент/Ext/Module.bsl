#Область СлужебныеПроцедурыИФункции

Функция КлючЗапускаПредприятия()
	Возврат "ENTERPRISE";
КонецФункции

Функция КлючЗапускаКонфигуратора()
	Возврат "DESIGNER";
КонецФункции

Функция КлючФайловойСтрокиПодключения()
	Возврат "/F";
КонецФункции

Функция КлючСервернойСтрокиПодключения()
	Возврат "/S";
КонецФункции

Функция КлючВебСервернойСтрокиПодключения()
	Возврат "/WS";
КонецФункции

Функция КлючОчисткиКэша()
	Возврат "/ClearCache";
КонецФункции

#Область Создание

Функция КлючСозданияИБ()
	Возврат "CREATEINFOBASE";
КонецФункции

Функция КлючФайловойСоздаваемойБазы()
	Возврат "File";
КонецФункции

