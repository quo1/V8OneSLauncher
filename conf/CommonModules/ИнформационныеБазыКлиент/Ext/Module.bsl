КонецФункции

#КонецОбласти

Асинх Функция СоздатьБазу(ОписаниеОповещенияЗакрытияФормыДобавления, ВладелецФормы = Неопределено) Экспорт
	Кнопки = Новый СписокЗначений;
	Кнопки.Добавить(КодОтветаСоздатьНовуюБазу(), "Создать новую");
	Кнопки.Добавить(КодОтветаДобавитьСуществующую(), "Добавить существующую");
	Кнопки.Добавить(Неопределено, "Отмена");
	
	Ответ = Ждать ВопросАсинх("Выберите тип добавляемой информационной базы.", Кнопки);
	
	Если Ответ = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	ТипДобавления = ?(Ответ = КодОтветаСоздатьНовуюБазу(),
		ИнформационныеБазыКлиентСервер.ТипДобавленияНоваяИБ(),
		ИнформационныеБазыКлиентСервер.ТипДобавленияСуществующаяИБ()
	);
	
	ПараметрыФормы = Новый Структура;
	ПараметрыФормы.Вставить("ТипДобавления", ТипДобавления);
	ОткрытьФорму("Справочник.ИнформационныеБазы.Форма.ФормаЭлемента", ПараметрыФормы, ВладелецФормы, , , ,
		ОписаниеОповещенияЗакрытияФормыДобавления);
КонецФункции

Асинх Функция УдалитьПапкуФайловойБазы(ПутьКПапке) Экспорт
	Папка = Новый Файл(ПутьКПапке);
	
	Если Ждать Папка.СуществуетАсинх() И Ждать Папка.ЭтоКаталогАсинх() Тогда
		Ждать УдалитьФайлыАсинх(Папка.ПолноеИмя);
	КонецЕсли;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

Функция ЗадатьВопросОбОткрытииПредприятия(ОписаниеИБ, ТипИБ) Экспорт
	Если ОписаниеИБ.ПредупреждатьПередОткрытиемПредприятия Тогда
		ДопПараметры = Новый Структура("ТипИБ, ОписаниеИБ", ТипИБ, ОписаниеИБ);
		
		ОповещениеОбОтветеНаВопрос = Новый ОписаниеОповещения("ОбработатьОтветНаВопросОбОткрытииПредприятия", ЭтотОбъект, ДопПараметры);
		ТекстВопроса = СтрШаблон("Вы уверены что хотите открыть ИБ ""%1"" в режиме предприятия?", ОписаниеИБ.Заголовок);
		Таймаут = 20;
		КнопкаПоУмолчанию = КодВозвратаДиалога.Нет;
		
		ПоказатьВопрос(ОповещениеОбОтветеНаВопрос,
			ТекстВопроса,
			РежимДиалогаВопрос.ДаНет,
			Таймаут,
			КнопкаПоУмолчанию,
			"Внимание!",
			КнопкаПоУмолчанию
		);
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

Процедура ОбработатьОтветНаВопросОбОткрытииПредприятия(Ответ, ДопПараметры = Неопределено) Экспорт
	Если Ответ = КодВозвратаДиалога.Нет ИЛИ Ответ = Неопределено ИЛИ Ответ = КодВозвратаДиалога.Таймаут Тогда
		Возврат;
	КонецЕсли;
	
	Если ДопПараметры.ТипИБ = ТипФайловойИБ() Тогда
		ПлатформаКлиент.ОткрытьПредприятиеФайловойБазы(ДопПараметры.ОписаниеИБ);
		
	ИначеЕсли ДопПараметры.ТипИБ = ТипСервернойИБ() Тогда
		ПлатформаКлиент.ОткрытьПредприятиеСервернойБазы(ДопПараметры.ОписаниеИБ);
		
	ИначеЕсли ДопПараметры.ТипИБ = ТипВебСервернойИБ() Тогда
		ПлатформаКлиент.ОткрытьПредприятиеВебСервернойБазы(ДопПараметры.ОписаниеИБ);
		
	КонецЕсли;
КонецПроцедуры

Функция ЕслиНужноВывестиСообщениеОЗапретеОткрытияКонфигуратора(ОписаниеИБ) Экспорт
	Если ОписаниеИБ.ЗапретитьОткрыватьКонфигуратор Тогда
		ТекстСообщения = СтрШаблон("Запрещено открывать конфигуратор ИБ ""%1""", ОписаниеИБ.Заголовок);
		ОбщегоНазначенияКлиентСервер.СообщитьПользователю(ТекстСообщения);
		
		Возврат Истина;
	КонецЕсли;
	
	Возврат Ложь;
КонецФункции

Асинх Функция ЗаполнитьУчетныеДанныеДляЗапуска(ОписаниеИБ)
	Если ЗначениеЗаполнено(ОписаниеИБ.Логин) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	УчетныеДанные = ИнформационныеБазыСлужебныйВызовСервера.УчетныеДанные(ОписаниеИБ.Ссылка);
	
	Если УчетныеДанные = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	УчетныеДанныеДляВыбора = Новый СписокЗначений;
	УчетныеДанныеДляВыбора.Добавить(Неопределено, "<стандартное окно логина>");
	
	Для Каждого Элемент Из УчетныеДанные Цикл
		УчетныеДанныеДляВыбора.Добавить(Элемент, Элемент.Наименование);
	КонецЦикла;
	
	ВыбранныйЭлемент = Ждать УчетныеДанныеДляВыбора.ВыбратьЭлементАсинх();
	
	Если НЕ (ВыбранныйЭлемент = Неопределено ИЛИ ВыбранныйЭлемент.Значение = Неопределено) Тогда
		ОписаниеИБ.Логин = ВыбранныйЭлемент.Значение.Логин;
		ОписаниеИБ.Пароль = ВыбранныйЭлемент.Значение.Пароль;
	КонецЕсли;
КонецФункции

Асинх Функция УдалитьЭлементСВопросом(ОписаниеЭлемента, ТипЭлемента)
	ДопПараметры = Новый Структура("ТипЭлемента, ОписаниеЭлемента", ТипЭлемента, ОписаниеЭлемента);
	
	ТекстВопроса = СтрШаблон("Вы уверены что хотите УДАЛИТЬ элемент ""%1""?", ОписаниеЭлемента.Заголовок);
	Таймаут = 5;
	КнопкаПоУмолчанию = КодВозвратаДиалога.Нет;
	
	ОтветНаВопрос = Ждать ВопросАсинх(ТекстВопроса, РежимДиалогаВопрос.ДаНет, Таймаут, КнопкаПоУмолчанию, "Внимание!", КнопкаПоУмолчанию);
	
	Если ОтветНаВопрос = КодВозвратаДиалога.Да Тогда
		ИнформационныеБазыСлужебныйВызовСервера.УдалитьЭлемент(ДопПараметры.ОписаниеЭлемента.Ссылка);
		
		Если ДопПараметры.ТипЭлемента = ТипФайловойИБ() Тогда
			Ждать УдалитьПапкуФайловойБазы(ДопПараметры.ОписаниеЭлемента.ПутьКПапке);
		КонецЕсли;
	КонецЕсли;
КонецФункции

Функция КодОтветаСоздатьНовуюБазу()
	Возврат 1;
КонецФункции

Функция КодОтветаДобавитьСуществующую()
	Возврат 2;
КонецФункции

